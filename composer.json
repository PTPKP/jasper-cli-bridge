{
    "name": "ptpkp/jasper-cli-bridge",
    "description": "PHP wrapper for JasperReports CLI - compile, fill and export JasperReports using JRXML templates",
    "type": "library",
    "keywords": [
        "jasper",
        "jasperreports",
        "reports",
        "pdf",
        "jrxml",
        "java",
        "cli-bridge"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "PT.PKP",
            "email": "amin.pkp001@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "PTPKP\\JasperCliBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PTPKP\\JasperCliBridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "build": "mvn clean package"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "PTPKP\\JasperCliBridge\\Laravel\\ServiceProvider"
            ],
            "aliases": {
                "Jasper": "PTPKP\\JasperCliBridge\\Laravel\\Facade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
